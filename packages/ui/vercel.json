{
  "rewrites": [
    { "source": "/install.sh", "destination": "/sh/cli/install.sh" },
    { "source": "/cli/:file", "destination": "/sh/cli/:file" },
    { "source": "/shared/:file", "destination": "/sh/shared/:file" },
    {
      "source": "/:cloud(local|digitalocean|gcp|aws|hetzner|daytona|sprite)/:script",
      "destination": "/sh/:cloud/:script"
    }
  ],
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/sh/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, stale-while-revalidate=300"
        }
      ]
    }
  ]
}
